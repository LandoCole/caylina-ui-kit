{
  "name": "@caylina/ui-kit",
  "version": "1.0.1",
  "description": "Caylina UI Kit — Lit Web Components (CDN-ready)",
  "type": "module",
  "main": "dist/caylina-ui.js",
  "module": "dist/caylina-ui.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/caylina-ui.js",
      "types": "./dist/types/index.d.ts"
    },
    "./tokens.css": "./dist/tokens.css",
    "./caylina-ui.js": "./dist/caylina-ui.js"
